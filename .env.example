# Configuración del servidor
NODE_ENV=development
PORT=3001

# Base de datos MySQL (uso futuro - Fase backend)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=app_transporte

# Seguridad / JWT (uso futuro)
JWT_SECRET=change_me
JWT_EXPIRES_IN=8h

# CORS (origen del frontend Vite). Separar múltiples orígenes con coma.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
